      "type": "stat",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total Tasks\" FROM tasks;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
