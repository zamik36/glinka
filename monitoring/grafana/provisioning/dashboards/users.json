{
  "title": "Glinka — Users",
  "uid": "glinka-users",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Всего пользователей",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS value FROM tasks",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Активных за 7 дней",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS value FROM tasks WHERE created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Всего задач",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM tasks",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Активных за 30 дней",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS value FROM tasks WHERE created_at > NOW() - INTERVAL '30 days'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Новые пользователи по дням",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', first_seen) AS \"time\", COUNT(*) AS \"new users\" FROM (SELECT user_id, MIN(created_at) AS first_seen FROM tasks GROUP BY user_id) t GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Задач создано по дням",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', created_at) AS \"time\", COUNT(*) AS \"tasks\" FROM tasks GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Топ пользователей по задачам",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "sortBy": [{ "displayName": "total_tasks", "desc": true }]
      },
      "targets": [
        {
          "rawSql": "SELECT user_id, COUNT(*) AS total_tasks, MIN(created_at)::date AS first_seen, MAX(created_at)::date AS last_seen FROM tasks GROUP BY user_id ORDER BY total_tasks DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Накопительный рост пользователей",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30 }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT first_seen AS \"time\", COUNT(*) OVER (ORDER BY first_seen) AS \"total users\" FROM (SELECT DISTINCT ON (user_id) user_id, date_trunc('day', MIN(created_at)) AS first_seen FROM tasks GROUP BY user_id) t ORDER BY first_seen",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRESQL",
        "type": "datasource",
        "query": "postgres",
        "hide": 2
      }
    ]
  }
}
