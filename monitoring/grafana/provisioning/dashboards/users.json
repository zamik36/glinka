    {
      "id": 5,
      "title": "Новые пользователи / день",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "rawSql": "SELECT first_seen::date AS time, COUNT(*) AS \"New Users\" FROM (SELECT user_id, MIN(created_at) AS first_seen FROM tasks GROUP BY user_id) sub GROUP BY first_seen::date ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "drawStyle": "bars",
            "barAlignment": 0,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 6,
      "title": "Задачи / день",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "rawSql": "SELECT created_at::date AS time, COUNT(*) AS \"Tasks\" FROM tasks GROUP BY created_at::date ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "drawStyle": "bars",
            "barAlignment": 0,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "id": 7,
      "title": "Топ пользователей по задачам",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "rawSql": "SELECT user_id AS \"User ID\", COUNT(*) AS \"Tasks\", COUNT(*) FILTER (WHERE is_completed) AS \"Completed\", ROUND(100.0 * COUNT(*) FILTER (WHERE is_completed) / NULLIF(COUNT(*), 0), 1) AS \"Completion %\" FROM tasks GROUP BY user_id ORDER BY \"Tasks\" DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Tasks", "desc": true }]
      }
    },
    {
      "id": 8,
      "title": "Кумулятивный рост пользователей",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "rawSql": "SELECT time, SUM(cnt) OVER (ORDER BY time) AS \"Cumulative Users\" FROM (SELECT MIN(created_at)::date AS time, COUNT(*) AS cnt FROM tasks GROUP BY user_id) sub ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list" }
      }
    }
  ],
