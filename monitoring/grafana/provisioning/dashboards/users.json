      "type": "stat",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS \"Active 7d\" FROM tasks WHERE created_at >= NOW() - INTERVAL '7 days';",
