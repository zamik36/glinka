      "id": 1,
      "title": "Всего пользователей",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS \"Total Users\" FROM tasks;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
