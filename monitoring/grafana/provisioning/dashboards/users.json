      "title": "Активных за 30 дней",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) AS \"Active 30d\" FROM tasks WHERE created_at >= NOW() - INTERVAL '30 days';",
